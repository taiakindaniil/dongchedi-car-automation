BOT_TOKEN=123456:your-telegram-bot-token-here
CHAT_ID=-1001234567890

HEADLESS=1

# Optional. Format: http://user:pass@host:port or socks5://host:port
# HTTP_PROXY=

# Optional override. Default reads ./config/filters.yaml
# CONFIG_PATH=./config/filters.yaml

# Optional override. Default ./data/seen.db
# DB_PATH=./data/seen.db

# Playwright Chromium profile (cookies persist between runs). Default ./data/playwright_profile
# PLAYWRIGHT_USER_DATA_DIR=./data/playwright_profile

# Cache for PUA→digit maps parsed from intercepted .woff2 (sha256-named JSON). Default ./data/font_map_cache
# FONT_MAP_CACHE_DIR=./data/font_map_cache

# Optional. Used to schedule cron in correct local time. Default Asia/Shanghai.
TIMEZONE=Asia/Shanghai

LOG_LEVEL=INFO
